<Window x:Class="WMDView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WMDView"
        mc:Ignorable="d"
        Title="WMDView" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="打开(_O)" x:Name="OpenMenuItem" Click="OpenMenuItem_Click" InputGestureText="Ctrl+O"/>
            </MenuItem>
        </Menu>
        <FlowDocumentScrollViewer Name="DocumentViewer" VerticalScrollBarVisibility="Auto">
            <FlowDocument Name="Document">
                <Paragraph>
                    <Run Text="WMDView - Markdown 查看器" FontSize="24" FontWeight="Bold"/>
                </Paragraph>
                <Paragraph>
                    <Run Text="请使用菜单或按 Ctrl+O 打开一个 Markdown 文件。"/>
                </Paragraph>
            </FlowDocument>
        </FlowDocumentScrollViewer>
    </DockPanel>
</Window>
